<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Transparent so the splash window bitmap shows through instead of white/ash. -->
    <style name="Theme.PotholeReport.Launch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/transparent</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_transparent</item>
        <item name="windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <item name="windowSplashScreenAnimationDuration">0</item>
        <item name="android:windowBackground">@drawable/splash_window_background</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="postSplashScreenTheme">@style/Theme.PotholeReport.SplashHost</item>
    </style>
</resources>
